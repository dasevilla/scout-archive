            },
            {
              "type": "text",
              "value": " DO ALL of the following:"
            }
          ],
          "resources": [],
          "sub_requirements": []
        },
        {
          "id": "15970",
          "label": "1",
          "content": [
            {
              "type": "text",
              "value": "Show your ability to select, use, and maintain equipment for cross-country skiing in safety and comfort."
